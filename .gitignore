# ── DATASETS  (not committed — download from Google Drive) ──────────────────
# Link: https://drive.google.com/drive/folders/1agc1hXlVinXAPM-7E8RFfAFopKVrIota
# Unzip / copy all files into datasets/ before running any training script.
datasets/*
!datasets/.gitkeep

# ── V1 model artifacts (CatBoost) ────────────────────────────────────────────
# Generated by: cd training && python preprocess.py && python train.py
# model_metadata.json is small JSON and intentionally tracked.
backend/model/*.pkl
training/data/
training/output/
training/catboost_info/

# V1 raw Dryad source data (large; included in the Google Drive folder above)
training/microbiology_cultures_demographics.csv
training/microbiology_cultures_microbial_resistance.csv

# ── V2 ARMD model artifacts (RandomForest) ───────────────────────────────────
# Generated by: cd armd_model && python train_armd.py && python train_dosage.py
armd_model/artifacts/*
!armd_model/artifacts/.gitkeep
