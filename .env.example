# ─────────────────────────────────────────────
# AURA — Environment Variable Template
# Copy this file to .env and fill in values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# ── Shared ──────────────────────────────────
ENVIRONMENT=development

# ── Backend ─────────────────────────────────

# Comma-separated list of CORS-allowed origins.
# Production example: https://your-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Uvicorn bind port (Render injects $PORT automatically)
PORT=8000

# Paths to trained model artifacts.
# These paths are relative to the working directory when the server starts.
MODEL_PATH=model/antibiotic_model.pkl
MODEL_METADATA_PATH=model/model_metadata.json
ARMD_ARTIFACTS_DIR=armd_model/artifacts

# ── Frontend ────────────────────────────────

# Client-side (browser) API base URL — must be publicly reachable.
# Development: http://localhost:8000
# Production example: https://your-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side API base URL used by Next.js during SSR.
# When running via Docker Compose use the container hostname.
API_URL=http://backend:8000
